# Required on Vercel (and recommended locally)
JWT_SECRET=use-a-long-random-string-at-least-32-characters

# Turso database (REQUIRED for Vercel hosting)
# Sign up at https://turso.tech — create a DB, then run:
#   turso db show <dbname> --url
#   turso db tokens create <dbname>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Local dev without Turso uses file:./data/daily-tracker.db automatically
