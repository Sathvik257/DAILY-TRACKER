# Required in production — use a long random string
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (default 3001)
PORT=3001

# SQLite database directory (default: ./data)
# DB_DIR=/var/data/daily-tracker

# Email (optional — daily reminders & welcome mail from "Daily Tracker")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Daily Tracker" <your-email@gmail.com>
